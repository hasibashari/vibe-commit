rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'hp', 'mana', 'level', 'exp']) 
        && data.name is string && data.name.size() <= 100
        && data.hp is number
        && data.mana is number
        && data.level is number
        && data.exp is number;
    }

    match /users/{userId} {
      allow list: if false;
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow delete: if false;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['user_id', 'title', 'difficulty'])
        && data.user_id is string && data.user_id == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.difficulty is number;
    }

    match /goals/{goalId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid && isValidId(goalId);
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && isValidId(goalId) 
        && incoming().user_id == existing().user_id 
        && isValidGoal(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid && isValidId(goalId);
    }

    function isValidQuestLog(data) {
      return data.keys().hasAll(['goal_id', 'user_id'])
        && data.goal_id is string && isValidId(data.goal_id)
        && data.user_id is string && data.user_id == request.auth.uid;
    }

    match /quest_logs/{logId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid && isValidId(logId);
      allow create: if isSignedIn() && isValidId(logId) && isValidQuestLog(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid && isValidId(logId);
    }

    function isValidBrainDump(data) {
      return data.keys().hasAll(['user_id', 'raw_content'])
        && data.user_id is string && data.user_id == request.auth.uid
        && data.raw_content is string && data.raw_content.size() <= 10000;
    }

    match /brain_dumps/{dumpId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid && isValidId(dumpId);
      allow create: if isSignedIn() && isValidId(dumpId) && isValidBrainDump(incoming());
      allow update: if false;
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid && isValidId(dumpId);
    }
  }
}
